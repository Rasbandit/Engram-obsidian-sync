#!/usr/bin/env bash
set -euo pipefail

# 1. Tests must pass.
bun test

# 2. Refuse to push branches whose package.json/manifest.json version still
#    matches origin/main. Bypass with: git push --no-verify
current_branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$current_branch" = "main" ] || [ "$current_branch" = "HEAD" ]; then
  exit 0
fi

if ! git rev-parse --verify --quiet origin/main >/dev/null; then
  exit 0
fi

extract_version() {
  node -p "require('./$1').version" 2>/dev/null || true
}

extract_main_version() {
  git show "origin/main:$1" 2>/dev/null \
    | node -e "let s='';process.stdin.on('data',c=>s+=c).on('end',()=>{try{console.log(JSON.parse(s).version)}catch{}})" \
    || true
}

for file in package.json manifest.json; do
  branch_v="$(extract_version "$file")"
  main_v="$(extract_main_version "$file")"
  if [ -n "$branch_v" ] && [ -n "$main_v" ] && [ "$branch_v" = "$main_v" ]; then
    cat >&2 <<EOF
✖ pre-push: $file version ($branch_v) has not been bumped from main.

  Bump with: npm version patch --no-git-tag-version
  (this updates package.json, manifest.json, versions.json together)

  To push WIP without bumping: git push --no-verify
EOF
    exit 1
  fi
done

echo "✓ pre-push: plugin version differs from main"
